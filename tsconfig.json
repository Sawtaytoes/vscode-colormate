{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "Node16",
    "lib": [
      "ES2022"
    ],
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"noUnusedParameters": true,
    "rootDir": "src",
    "skipLibCheck": true, // TEMP: This is breaking because of bad types in `vscode-oniguruma`.
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
  },
  "exclude": [
    ".vscode-test",
    "node_modules"
  ],
}
